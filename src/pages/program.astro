---
//@ts-nocheck
import Layout from "../layouts/Layout.astro";
import Kunstner from "../components/Kunstner.astro";

const url = `https://qvojbjzhnzwsmxjbsnze.supabase.co/rest/v1/artistCard?select=*`;
const apiKey = "sb_publishable_Ik-Cm_IdDH9hqrY-8tragg_fTz_0YjC";

const options = {
  headers: {
    apikey: apiKey,
  },
};

const data = await fetch(url, options).then((res) => res.json());

console.log(data);
---

<Layout title="Program">
  <div class="hero">
    <img src="img/program.webp" alt="Band" />
    <h1>Program</h1>
  </div>

  {data.map((artist) => <Kunstner artist={artist} />)}
</Layout>

<style>
  /* hero */
  img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero {
    position: relative;
  }

  .hero h1 {
    position: absolute;
    top: 15%;
    left: 50%;
    transform: translate(-50%, -30%);
  }

  /* mobil */
  @media (max-width: 900px) {
    .hero h1 {
      font-size: 75px;
      top: 10%;
    }

     .hero h1 {
    position: absolute;
    top: 25%;
    left: 50%;
    transform: translate(-50%, -30%);
  }

  }
</style>
