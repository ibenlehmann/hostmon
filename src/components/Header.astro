---
import Layout from "../layouts/Layout.astro";
---

<header class="header">
  <nav class="nav">
    <a href="/" class="logo">
      <img src="/img/logo2.png" />
    </a>

    <div class="navudenlogo">
      <ul class="menu">
        <li><a href="/program">Program</a></li>
        <li><a href="/frivillige">Frivillige</a></li>
        <li><a href="/faellesspisning">Fællesspisning</a></li>
        <li><a href="/om">Om</a></li>
      </ul>

      <div class="nav_right">
        <a href="/" class="cta">Billetter</a>

        <button class="burger"> ☰ </button>
      </div>
    </div>
  </nav>

  <style>
    .header {
      /*padding: 20px;*/
      font-family: "Poppins", sans-serif;
      z-index: 1000;
      top: 0;
      position: absolute;
      width: 100%;

      /*left: 0;*/
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      /*max-width: 1200px;
      margin: 0 auto;*/
      padding: 20px 40px;
    }

    .logo img {
      height: 80px;
      width: auto;
    }

    .burger {
      display: block;
      font-size: 2rem;
      background: none;
      border: none;
      cursor: pointer;
      color: black;
    }

    .menu {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 75px;
      right: 30px;
      background: transparent;
      padding: 20px;
      gap: 15px;
      list-style: none;
      border-radius: 10px;
    }
    .nav_right {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 10px;
      /*padding-left: 10rem;*/
    }
    .menu a {
      text-decoration: none;
      color: var(--color-cta);
      font-weight: 600;
      font-size: 1rem;
    }
    .menu.active {
      display: flex;
    }

    .cta {
      display: inline-block;
      background: var(--color-cta);
      color: var(--color-yellow);
      padding: 12px 24px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: bold;
    }
    .cta:hover {
      background-color: var(--color-red);
      color: var(--color-yellow);
    }
    @media (min-width: 800px) {
      .menu {
        display: flex;
        flex-direction: row;
        position: static;
        background: none;
        padding: 0;
        gap: 40px;

        margin-left: auto;
        margin-right: 40px;
      }
      .burger {
        display: none;
      }

      .menu a {
        text-decoration: none;
        color: var(--color-cta);
        font-weight: 600;
        font-size: 1.2rem;
      }

      .cta {
        display: inline-block;
        background: var(--color-cta);
        color: var(--color-yellow);
        padding: 12px 24px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: bold;
      }

      .logo {
        margin-inline-end: auto;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .navudenlogo {
        display: grid;
        grid-template-columns: auto auto;
      }
    }
  </style>

  <script>
    document.querySelector(".burger").addEventListener("click", () => {
      document.querySelector(".menu").classList.toggle("active");
    });
  </script>
</header>
