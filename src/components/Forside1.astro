---
import Layout from "../layouts/Layout.astro";
---

<section class="hero">
  <div class="hero_indhold">
    <h1>HØST MØN</h1>
    <p class="dato">28–29. august</p>
    <button>BILLETTER</button>
  </div>
</section>

<section class="artists">
  <h2>ARTISTER</h2>

  <div class="carousel">
    <button class="pil venstre">❮</button>

    <div class="artist-row">
      <div class="artist lille">
        <img src="/img/maikevoss2.webp" alt="Majke Voss" />
        <p>MAJKE VOSS</p>
      </div>

      <div class="artist stor">
        <img src="/img/snuggle2.webp" alt="Snuggle" />
        <p>SNUGGLE</p>
      </div>

      <div class="artist lille">
        <img src="/img/miaww2.webp" alt="Miaww" />
        <p>MIAWW</p>
      </div>
    </div>

    <button class="pil højre">❯</button>
  </div>
</section>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .hero {
    height: 70vh;
    background: url("/img/forside.webp") center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
  }

  .hero_indhold {
    color: white;
  }

  .hero h1 {
    letter-spacing: 2px;
    font-size: 75px;
  }

  .dato {
    margin: 0.5rem 0 1.5rem;
    color: var(--color-green);
    font-size: 1.2rem;
  }

  .hero button {
    border: none;
    padding: 0.8rem 2rem;
    border-radius: 999px;
  }

  .artists {
    background-color: var(--color-yellow);
    padding: 3rem 1rem;
    text-align: center;
    padding-bottom: 5rem;
  }

  .artists h2 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }

  .carousel {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .pil {
    background: none;
    border: none;
    font-size: 2rem;
    color: var(--color-red);
    cursor: pointer;
  }

  .artist-row {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 1rem;
  }

  .artist {
    position: relative;
    border-radius: 12px;
    transition: transform 0.3s ease;
  }

  .artist img {
    width: 100%;
    object-fit: cover;
    display: block;
  }

  .artist.lille {
    width: 120px;
  }

  .artist.lille img {
    height: 140px;
  }

  .artist.stor {
    width: 150px;
  }

  .artist.stor img {
    height: 185px;
  }

  .artist p {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;

    text-align: center;
    color: var(--color-green);
    font-weight: bold;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
  }

  .artist.lille p {
    font-size: 0.9rem;
  }

  .artist.stor p {
    font-size: 1.7rem;
  }

  @media (min-width: 768px) {
    .hero {
      height: 90vh;
    }

    .hero h1{
      font-size: 150px;
    }

    .dato {
      font-size: 1.5rem;
    }

    .artist img {
      height: 360px;
    }
    .artist.stor {
      width: 340px;
    }

    .artist.stor img {
      height: 380px;
    }

    .artist.lille {
      width: 260px;
    }

    .artist.lille img {
      height: 300px;
    }

    .artists h2 {
      font-size: 4rem;
    }

    .artist.lille p {
      font-size: 2rem;
    }

    .artist.stor p {
      font-size: 4rem;
    }

    .pil {
      font-size: 3rem;
    }
  }
</style>
